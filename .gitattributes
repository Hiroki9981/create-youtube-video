# デフォルト: テキストファイルの改行をGitが自動判定
* text=auto

# コードファイルはLFに統一（OS関係なく一貫性を保つ）
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# バイナリファイルは変換しない
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.wav  binary
*.mp3  binary
*.mp4  binary
*.mov  binary
*.webm binary
